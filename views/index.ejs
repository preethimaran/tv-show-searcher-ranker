<!DOCTYPE html>
<html lang="en" data-theme="light">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Roboto+Flex:opsz,wght,XOPQ,XTRA,YOPQ,YTDE,YTFI,YTLC,YTUC@8..144,100..1000,96,468,79,-203,738,514,712&family=Silkscreen:wght@400;700&display=swap"
        rel="stylesheet">
    <link rel='stylesheet' href="/css/styles.css">
    <title>Document</title>
</head>

<body>
    <button type="button" id="color-theme-toggler" data-theme-toggle aria-label="Change the website theme"><span></span>
        <img></button>
    <h1 class="silkscreen-bold">Search Your Favorite TV Shows &lt;3</h1>
    <form id="searchForm">
        <input type="text" placeholder="TV Show Title" name="query">
        <button class="silkscreen-regular">Search</button>
    </form>
    <div class="images no-visible task-area" id="startSpace">
    </div>

    <div class="all-ratings">

        <div class="images no-visible rating-box task-area" id="5 STAR">
            <h3 class="silkscreen-bold">5 STARS &lt;3</h3>
            <div class="inner"></div>
        </div>

        <div class="images no-visible rating-box task-area" id="4 STAR">
            <h3 class="silkscreen-bold">4 STARS &lt;3</h3>
            <div class="inner"></div>
        </div>

        <div class="images no-visible rating-box task-area" id="3 STAR">
            <h3 class="silkscreen-bold">3 STARS &lt;3</h3>
            <div class="inner"></div>
        </div>

        <div class="images no-visible rating-box task-area" id="2 STAR">
            <h3 class="silkscreen-bold">2 STARS</h3>
            <div class="inner"></div>
        </div>

        <div class="images no-visible rating-box task-area" id="1 STAR">
            <h3 class="silkscreen-bold">1 STAR</h3>
            <div class="inner"></div>
        </div>
    </div>
    <script src="/js/app.js"></script>
</body>

</html>